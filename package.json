    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3.8.3",
