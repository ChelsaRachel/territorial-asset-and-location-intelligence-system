    "d3-brush": "^3.0.0",
    "d3-scale": "^4.0.2",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.23.1",
    "next": "14.2.35",
    "nuqs": "^2.8.9",
    "pptxgenjs": "^3.12.0",
    "react": "^18",
    "react-dom": "^18",
    "react-map-gl": "^8.1.1",
